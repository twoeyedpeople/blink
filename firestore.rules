rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidProject(data) {
      return data.name is string &&
             data.name.size() > 0 &&
             data.clientName is string &&
             data.tasks is list &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    match /projects/{projectId} {
      // Prototype mode: public read/write for shared timelines, but enforce shape and doc ID.
      allow read: if true;
      allow create, update: if isValidProject(request.resource.data) &&
                             request.resource.data.id == projectId;
      allow delete: if true;
    }

    match /people/{personId} {
      allow read, write: if true;
    }

    // Blink (time tracker) workspace document. One doc holds every project,
    // rate and time entry for every client, so unlike Chronos's own
    // collections above this is NOT left open to anonymous read/write:
    // it requires (anonymous, no-login) Firebase Auth, which keeps it off
    // limits to anyone who's just grabbed the public web config.
    function isValidBlinkWorkspace(data) {
      return data.projects is list &&
             data.entries is list &&
             data.prefs is map &&
             data.updatedAt is number;
    }

    match /blink/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isValidBlinkWorkspace(request.resource.data);
    }

    // Redacted, per-project mirror powering the client-facing billing link
    // (blink_clients/{shareId}). Deliberately public read, an unguessable
    // shareId in the URL is the only access control, a client bookmarks it
    // with no login. Write stays gated the same way as the workspace doc,
    // only Blink's own session ever publishes to these.
    function isValidClientView(data) {
      return data.projectName is string &&
             data.hourlyRate is number &&
             data.entries is list &&
             data.updatedAt is number;
    }

    match /blink_clients/{shareId} {
      allow read: if true;
      allow write: if request.auth != null && isValidClientView(request.resource.data);
    }
  }
}
